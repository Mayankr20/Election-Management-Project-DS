#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// --- Structures ---

struct Candidate {
    int id;
    char name[50];
    char party[50];
    char constituency[50];
    char symbol[20];
    int age;
    int votes;
    struct Candidate* next;
};

struct Voter {
    int voterId;
    char name[50];
    char address[100];
    int age; // Added age to voter struct for consistency
    int hasVoted; 
    struct Voter* next;
};

// Global Pointers
struct Candidate* candidateHead = NULL;
struct Voter* voterHead = NULL;

// --- Helper Functions ---

int isIdDuplicate(int id) {
    struct Candidate* cTemp = candidateHead;
    while (cTemp != NULL) {
        if (cTemp->id == id) return 1;
        cTemp = cTemp->next;
    }
    struct Voter* vTemp = voterHead;
    while (vTemp != NULL) {
        if (vTemp->voterId == id) return 1;
        vTemp = vTemp->next;
    }
    return 0;
}

struct Voter* findVoter(int id) {
    struct Voter* temp = voterHead;
    while (temp != NULL) {
        if (temp->voterId == id) return temp;
        temp = temp->next;
    }
    return NULL;
}

void internalRegisterVoter(int id, char* name, char* address, int age) {
    struct Voter* newNode = (struct Voter*)malloc(sizeof(struct Voter));
    newNode->voterId = id;
    strcpy(newNode->name, name);
    strcpy(newNode->address, address);
    newNode->age = age;
    newNode->hasVoted = 0;
    newNode->next = voterHead;
    voterHead = newNode;
}

// --- Core Logic ---

void addVoter() {
    int id, age;
    printf("\nEnter Voter ID: ");
    scanf("%d", &id);

    if (isIdDuplicate(id)) {
        printf("Error: ID %d is already registered!\n", id);
        return;
    }

    printf("Enter Age: ");
    scanf("%d", &age);
    if (age < 18) {
        printf("Error: Voter must be at least 18 years old to register.\n");
        return;
    }

    char name[50], address[100];
    printf("Enter Name: ");
    scanf(" %[^\n]", name);
    printf("Enter Address: ");
    scanf(" %[^\n]", address);

    internalRegisterVoter(id, name, address, age);
    printf("Voter registered successfully!\n");
}

void addCandidate() {
    int id, age;
    printf("\nEnter Candidate ID: ");
    scanf("%d", &id);

    if (isIdDuplicate(id)) {
        printf("Error: ID %d is already taken!\n", id);
        return;
    }

    printf("Enter Age: ");
    scanf("%d", &age);
    if (age < 18) {
        printf("Error: Candidate must be at least 18 years old to contest.\n");
        return;
    }

    struct Candidate* newNode = (struct Candidate*)malloc(sizeof(struct Candidate));
    newNode->id = id;
    newNode->age = age;
    
    printf("Enter Name: ");
    scanf(" %[^\n]", newNode->name);
    printf("Enter Party: ");
    scanf(" %[^\n]", newNode->party);
    printf("Enter Constituency: ");
    scanf(" %[^\n]", newNode->constituency);
    printf("Enter Party Symbol: ");
    scanf(" %[^\n]", newNode->symbol);
    
    newNode->votes = 0;
    newNode->next = candidateHead;
    candidateHead = newNode;

    // Candidate automatically registered as a voter
    internalRegisterVoter(id, newNode->name, "Candidate Residence", age);

    printf("\nCandidate %s added and auto-registered as a voter!\n", newNode->name);
}

void castVote() {
    int vId, cId;
    if (candidateHead == NULL) {
        printf("\nNo candidates registered!\n");
        return;
    }

    printf("\nEnter your unique Voter ID: ");
    scanf("%d", &vId);

    struct Voter* voter = findVoter(vId);
    if (voter == NULL) {
        printf("\nError: ID not found in registry!\n");
        return;
    }

    if (voter->hasVoted) {
        printf("\nAccess Denied: %s has already voted!\n", voter->name);
        return;
    }

    printf("Enter Candidate ID to vote for: ");
    scanf("%d", &cId);

    struct Candidate* temp = candidateHead;
    while (temp != NULL) {
        if (temp->id == cId) {
            temp->votes++;
            voter->hasVoted = 1; 
            printf("\nVote successful: %s voted for %s!\n", voter->name, temp->name);
            return;
        }
        temp = temp->next;
    }
    printf("\nCandidate ID %d not found.\n", cId);
}

void displayResults() {
    struct Candidate* temp = candidateHead;
    if (temp == NULL) {
        printf("\nNo candidates to display.\n");
        return;
    }
    printf("\n%-5s %-15s %-15s %-5s %-10s\n", "ID", "Name", "Party", "Age", "Votes");
    while (temp != NULL) {
        printf("%-5d %-15s %-15s %-5d %-10d\n", temp->id, temp->name, temp->party, temp->age, temp->votes);
        temp = temp->next;
    }
}

void cleanup() {
    while (candidateHead != NULL) {
        struct Candidate* temp = candidateHead;
        candidateHead = candidateHead->next;
        free(temp);
    }
    while (voterHead != NULL) {
        struct Voter* temp = voterHead;
        voterHead = voterHead->next;
        free(temp);
    }
}

int main() {
    int choice, numVoters;

    printf("--- Voter Registration Phase ---\n");
    printf("How many voters would you like to register initially? ");
    scanf("%d", &numVoters);
    for(int i = 0; i < numVoters; i++) {
        printf("\nRegistering Voter %d:", i + 1);
        addVoter();
    }

    while (1) {
        printf("\n--- Election Management System ---");
        printf("\n1. Add More General Voters\n2. Add Candidate\n3. Cast Vote\n4. Display Results\n5. Exit\nChoice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1: addVoter(); break;
            case 2: addCandidate(); break;
            case 3: castVote(); break;
            case 4: displayResults(); break;
            case 5: cleanup(); exit(0);
            default: printf("Invalid choice.\n");
        }
    }
    return 0;
}
