#include <stdio.h>
#include <stdlib.h>
#include <string.h>

// Structure for Candidates
struct Candidate {
    int id;
    char name[50];
    char party[50];
    int votes;
    struct Candidate* next;
};

// Structure to track Voter IDs to prevent duplicate voting
struct Voter {
    int voterId;
    struct Voter* next;
};

// Global Pointers
struct Candidate* head = NULL;
struct Voter* voterHead = NULL;

// --- Function Prototypes ---
int isDuplicateCandidate(int id);
int hasVoted(int vId);
void addCandidate();
void castVote();
void displayResults();
void findWinner();
void cleanupMemory();

// Check if a Candidate ID already exists
int isDuplicateCandidate(int id) {
    struct Candidate* temp = head;
    while (temp != NULL) {
        if (temp->id == id) return 1;
        temp = temp->next;
    }
    return 0;
}

// Check if a Voter ID has already cast a vote
int hasVoted(int vId) {
    struct Voter* temp = voterHead;
    while (temp != NULL) {
        if (temp->voterId == vId) return 1;
        temp = temp->next;
    }
    return 0;
}

// 1. Add Candidate
void addCandidate() {
    int id;
    printf("\nEnter Candidate ID: ");
    if (scanf("%d", &id) != 1) {
        printf("Invalid input.\n");
        while(getchar() != '\n'); // clear buffer
        return;
    }

    if (isDuplicateCandidate(id)) {
        printf("\nError: Candidate ID %d is already taken.\n", id);
        return;
    }

    struct Candidate* newNode = (struct Candidate*)malloc(sizeof(struct Candidate));
    if (!newNode) {
        printf("Memory allocation failed!\n");
        return;
    }

    newNode->id = id;
    printf("Enter Name: ");
    scanf(" %49[^\n]", newNode->name); // Limited to 49 to prevent overflow
    printf("Enter Party: ");
    scanf(" %49[^\n]", newNode->party);
    
    newNode->votes = 0;
    newNode->next = NULL;

    if (head == NULL) {
        head = newNode;
    } else {
        struct Candidate* temp = head;
        while (temp->next != NULL) {
            temp = temp->next;
        }
        temp->next = newNode;
    }
    printf("\nCandidate %s added successfully!\n", newNode->name);
}

// 2. Cast Vote
void castVote() {
    int vId, cId;
    if (head == NULL) {
        printf("\nNo candidates registered yet!\n");
        return;
    }

    printf("\nEnter your unique Voter ID: ");
    scanf("%d", &vId);

    if (hasVoted(vId)) {
        printf("\nAccess Denied: Voter ID %d has already cast a vote!\n", vId);
        return;
    }

    printf("Enter Candidate ID to vote for: ");
    scanf("%d", &cId);

    struct Candidate* temp = head;
    while (temp != NULL) {
        if (temp->id == cId) {
            temp->votes++;
            
            // Record Voter
            struct Voter* newVoter = (struct Voter*)malloc(sizeof(struct Voter));
            newVoter->voterId = vId;
            newVoter->next = voterHead;
            voterHead = newVoter;

            printf("\nVote cast successfully for %s!\n", temp->name);
            return;
        }
        temp = temp->next;
    }
    printf("\nCandidate ID %d not found.\n", cId);
}

// 3. Display Results
void displayResults() {
    struct Candidate* temp = head;
    if (temp == NULL) {
        printf("\nNo candidates to display.\n");
        return;
    }
    printf("\n--- Election Results ---\n");
    printf("%-10s %-20s %-20s %-10s\n", "ID", "Name", "Party", "Votes");
    while (temp != NULL) {
        printf("%-10d %-20s %-20s %-10d\n", temp->id, temp->name, temp->party, temp->votes);
        temp = temp->next;
    }
}

// 4. Find Winner
void findWinner() {
    if (head == NULL) {
        printf("\nNo candidates registered.\n");
        return;
    }
    struct Candidate *temp = head, *winner = head;
    int tie = 0;

    while (temp != NULL) {
        if (temp->votes > winner->votes) {
            winner = temp;
            tie = 0;
        } else if (temp->votes == winner->votes && temp != winner) {
            tie = 1;
        }
        temp = temp->next;
    }

    if (winner->votes == 0) {
        printf("\nNo votes have been cast yet.\n");
    } else if (tie) {
        printf("\nIt's currently a tie! Leading candidate: %s with %d votes.\n", winner->name, winner->votes);
    } else {
        printf("\nWINNER: %s from %s with %d votes!\n", winner->name, winner->party, winner->votes);
    }
}

// 5. Cleanup memory before exit
void cleanupMemory() {
    struct Candidate* cTemp;
    while (head != NULL) {
        cTemp = head;
        head = head->next;
        free(cTemp);
    }
    struct Voter* vTemp;
    while (voterHead != NULL) {
        vTemp = voterHead;
        voterHead = voterHead->next;
        free(vTemp);
    }
}

int main() {
    int choice;
    while (1) {
        printf("\n--- Election Management System ---");
        printf("\n1. Add Candidate");
        printf("\n2. Cast Vote");
        printf("\n3. Display Results");
        printf("\n4. Find Winner");
        printf("\n5. Exit");
        printf("\nEnter choice: ");
        
        if (scanf("%d", &choice) != 1) {
            printf("Invalid Input. Use numbers 1-5.\n");
            while(getchar() != '\n'); 
            continue;
        }

        switch (choice) {
            case 1: addCandidate(); break;
            case 2: castVote(); break;
            case 3: displayResults(); break;
            case 4: findWinner(); break;
            case 5: 
                cleanupMemory();
                printf("Exiting and cleaning memory...\n");
                exit(0);
            default: printf("\nInvalid Choice!\n");
        }
    }
    return 0;
}
