#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

// --- Constants & Enums ---
#define ADMIN_PASS "secure2024"

typedef enum { REGISTRATION, VOTING, CLOSED } ElectionPhase;

// --- Structures ---
struct Candidate {
    int id;
    char name[50];
    char party[50];
    char symbol[20];
    int votes;
    struct Candidate* next;
};

struct Voter {
    int voterId;
    char name[50];
    int voterType; // 0: General, 1: Candidate
    int hasVoted; 
    struct Voter* next;
};

// Global State
struct Candidate* candidateHead = NULL;
struct Voter* voterHead = NULL;
ElectionPhase currentPhase = REGISTRATION;

// --- Audit & Utility ---
void logAction(const char* action) {
    time_t now;
    time(&now);
    printf("[AUDIT LOG %s] %s\n", strtok(ctime(&now), "\n"), action);
}

struct Voter* findVoter(int id) {
    struct Voter* temp = voterHead;
    while (temp) {
        if (temp->voterId == id) return temp;
        temp = temp->next;
    }
    return NULL;
}

// --- Logic Modules ---

void registerVoter() {
    if (currentPhase != REGISTRATION) {
        printf("Error: Registration phase has ended.\n");
        return;
    }
    int id;
    printf("Enter Voter ID: "); scanf("%d", &id);
    if (findVoter(id)) { printf("Conflict: ID already exists.\n"); return; }
    
    struct Voter* newNode = (struct Voter*)malloc(sizeof(struct Voter));
    newNode->voterId = id;
    printf("Enter Full Name: "); scanf(" %[^\n]", newNode->name);
    newNode->voterType = 0; 
    newNode->hasVoted = 0;
    newNode->next = voterHead;
    voterHead = newNode;
    
    logAction("New voter registered.");
}

void nominateCandidate() {
    if (currentPhase != REGISTRATION) {
        printf("Error: Nomination phase has ended.\n");
        return;
    }
    int id;
    printf("Enter Candidate ID: "); scanf("%d", &id);
    if (findVoter(id)) { printf("Conflict: ID already in use.\n"); return; }

    struct Candidate* newNode = (struct Candidate*)malloc(sizeof(struct Candidate));
    newNode->id = id;
    printf("Enter Candidate Name: "); scanf(" %[^\n]", newNode->name);
    printf("Enter Party Name: "); scanf(" %[^\n]", newNode->party);
    printf("Enter Symbol: "); scanf(" %[^\n]", newNode->symbol);
    newNode->votes = 0;
    newNode->next = candidateHead;
    candidateHead = newNode;

    // Auto-register candidate as a Type 1 voter (cannot vote)
    struct Voter* vNode = (struct Voter*)malloc(sizeof(struct Voter));
    vNode->voterId = id;
    strcpy(vNode->name, newNode->name);
    vNode->voterType = 1;
    vNode->hasVoted = 0;
    vNode->next = voterHead;
    voterHead = vNode;

    logAction("Candidate nomination accepted.");
}

void processVote() {
    if (currentPhase != VOTING) {
        printf("Error: Voting booth is currently closed.\n");
        return;
    }
    int vid, cid;
    printf("Verification - Enter Voter ID: "); scanf("%d", &vid);
    struct Voter* v = findVoter(vid);

    if (!v || v->voterType != 0) {
        printf("Security Alert: Unauthorized ID or Candidate attempting to vote.\n");
        return;
    }
    if (v->hasVoted) {
        printf("Access Denied: Duplicate voting attempt detected.\n");
        return;
    }

    printf("Ballot - Enter Candidate ID: "); scanf("%d", &cid);
    struct Candidate* c = candidateHead;
    while(c) {
        if (c->id == cid) {
            c->votes++;
            v->hasVoted = 1;
            logAction("Secure vote cast successfully.");
            return;
        }
        c = c->next;
    }
    printf("Error: Invalid Candidate ID.\n");
}

void generateReports() {
    char pass[20];
    printf("Access Restricted. Enter Admin Password: "); scanf("%s", pass);
    if (strcmp(pass, ADMIN_PASS) != 0) { printf("Unauthorized Access!\n"); return; }

    printf("\n--- ELECTION AUDIT REPORT ---\n");
    struct Candidate* c = candidateHead;
    while(c) {
        printf("[%s] %s: %d votes\n", c->party, c->name, c->votes);
        c = c->next;
    }
}

int main() {
    int choice;
    while (1) {
        printf("\nPHASE: %s | 1.Voter Reg | 2.Nominate | 3.Start Voting | 4.CAST VOTE | 5.Report | 6.Exit\nChoice: ", 
               currentPhase == REGISTRATION ? "REGISTRATION" : (currentPhase == VOTING ? "VOTING" : "CLOSED"));
        scanf("%d", &choice);
        switch(choice) {
            case 1: registerVoter(); break;
            case 2: nominateCandidate(); break;
            case 3: currentPhase = VOTING; logAction("Election phase moved to VOTING."); break;
            case 4: processVote(); break;
            case 5: generateReports(); break;
            case 6: exit(0);
        }
    }
    return 0;
}
